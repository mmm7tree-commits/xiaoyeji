.home-page {
  padding-bottom: 108rpx;
}

.hero,
.section-card {
  padding: 28rpx;
  border-radius: 36rpx;
}

.hero {
  background: rgba(255, 253, 248, 0.98);
  border-color: rgba(119, 168, 105, 0.16);
  box-shadow: 0 18rpx 42rpx rgba(111, 153, 93, 0.12);
}

.hero-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-logo {
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
}

.hero-brand-copy {
  min-width: 0;
}

.hero-brand {
  color: #394334;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-brand-subtitle {
  margin-top: 8rpx;
  color: #74806f;
  font-size: 24rpx;
  line-height: 1.4;
}

.hero-copy {
  margin-top: 28rpx;
}

.hero-title {
  color: #394334;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 1rpx;
}

.hero-text {
  margin-top: 22rpx;
  color: #74806f;
  font-size: 28rpx;
  line-height: 1.72;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-tags .pill {
  min-height: 72rpx;
  padding: 0 30rpx;
  color: #5bb55d;
  font-size: 24rpx;
  font-weight: 700;
  background: #eef9e8;
}

.hero-section-head {
  margin-top: 58rpx;
  margin-bottom: 20rpx;
}

.section-kicker {
  color: #e67a48;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-title {
  margin-top: 14rpx;
  color: #394334;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-subtitle {
  margin-top: 14rpx;
  color: #74806f;
  font-size: 26rpx;
  line-height: 1.72;
}

.loading-card {
  text-align: left;
}

.retry-btn {
  width: 100%;
  margin-top: 24rpx;
}

.template-section {
  margin-top: 28rpx;
}

.section-card {
  background: rgba(255, 253, 248, 0.98);
  border-color: rgba(119, 168, 105, 0.16);
  box-shadow: 0 18rpx 42rpx rgba(111, 153, 93, 0.1);
}

.section-card-head {
  margin-bottom: 0;
}

.featured-template {
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 226, 141, 0.2), transparent 260rpx),
    linear-gradient(180deg, #fffef9, #f8fdf5);
  border: 2rpx solid rgba(120, 190, 112, 0.18);
  box-shadow: 0 14rpx 28rpx rgba(111, 153, 93, 0.1);
}

.featured-focus {
  display: flex;
  align-items: stretch;
  gap: 22rpx;
}

.featured-visual {
  position: relative;
  flex: 0 0 224rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.featured-cover-shell {
  width: 224rpx;
  height: 296rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  background: #fffefb;
  box-shadow: 0 10rpx 20rpx rgba(101, 145, 93, 0.12);
}

.featured-cover,
.featured-cover-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.featured-cover-placeholder {
  background: #f1f6ed;
}

.featured-visual-badge {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e7f4d6;
  color: #607757;
  font-size: 20rpx;
  font-weight: 700;
}

.featured-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.featured-kicker {
  color: #e67a48;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.featured-title {
  margin-top: 14rpx;
  color: #394334;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.24;
}

.featured-text {
  margin-top: 16rpx;
  color: #74806f;
  font-size: 26rpx;
  line-height: 1.68;
}

.featured-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.featured-meta .pill {
  min-height: 60rpx;
  padding: 0 22rpx;
  color: #65715e;
  font-size: 23rpx;
  font-weight: 700;
  background: #f2f7ef;
}

.featured-btn {
  width: 100%;
  margin-top: 26rpx;
}

.category-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 34rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 254, 250, 0.96);
  border: 2rpx solid rgba(115, 168, 102, 0.2);
}

.category-chip.active {
  background: #eef9e8;
  border-color: rgba(115, 182, 99, 0.26);
}

.category-name {
  color: #66735f;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.category-chip.active .category-name {
  color: #5bb55d;
}

.template-list {
  margin-top: 20rpx;
}

.template-list-card {
  display: flex;
  align-items: stretch;
  justify-content: flex-start;
  margin-top: 18rpx;
  padding: 24rpx;
  gap: 18rpx;
  border-radius: 36rpx;
  border-color: rgba(120, 190, 112, 0.18);
  background: linear-gradient(180deg, #fffef9, #fafdf6);
  box-shadow: 0 14rpx 28rpx rgba(111, 153, 93, 0.08);
}

.template-list-card:first-child {
  margin-top: 0;
}

.template-list-cover {
  width: 152rpx;
  height: 200rpx;
  flex: 0 0 auto;
  border-radius: 22rpx;
  object-fit: cover;
  background: #f2f8ed;
}

.template-list-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.template-list-main {
  min-width: 0;
}

.template-list-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.template-list-title {
  color: #394334;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.template-list-price {
  color: #e67a48;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.template-list-summary {
  margin-top: 14rpx;
  color: #74806f;
  font-size: 25rpx;
  line-height: 1.68;
}

.template-list-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.template-list-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.template-list-tags .pill {
  min-height: 50rpx;
  padding: 0 18rpx;
  color: #65715e;
  font-size: 21rpx;
  font-weight: 700;
  background: #f2f7ef;
}

.template-list-action {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #fff0e4;
  color: #e67a48;
  font-size: 34rpx;
  font-weight: 700;
}

.template-list-action.is-selected {
  background: rgba(120, 200, 103, 0.16);
  color: #5bb55d;
}

.bottom-entry-bar {
  margin-top: 22rpx;
  padding: 0 8rpx 8rpx;
}

.entry-action-row {
  display: flex;
  gap: 18rpx;
}

.entry-secondary-btn {
  flex: 0 0 196rpx;
  min-height: 84rpx;
}

.entry-primary-btn {
  flex: 1;
  min-height: 92rpx;
}
