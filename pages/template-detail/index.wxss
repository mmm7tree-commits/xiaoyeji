.template-detail-page {
  padding-bottom: 72rpx;
}

.detail-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-card {
  overflow: hidden;
}

.detail-cover {
  width: 100%;
  height: 420rpx;
  border-radius: 28rpx;
}

.detail-pills,
.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-pills {
  margin-top: 24rpx;
}

.detail-title {
  margin-top: 18rpx;
  color: #2e2823;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.18;
}

.detail-text {
  margin-top: 16rpx;
  color: #65716d;
  font-size: 26rpx;
  line-height: 1.8;
}

.detail-meta-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-meta-card {
  flex: 1;
}

.detail-meta-label {
  color: #7f8a86;
  font-size: 22rpx;
}

.detail-meta-value {
  margin-top: 10rpx;
  color: #2e2823;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.field-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 22rpx;
}

.field-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  color: #2e2823;
  font-size: 24rpx;
  font-weight: 700;
}

.field-input,
.field-textarea {
  width: 100%;
  padding: 24rpx 24rpx;
  color: #2e2823;
  font-size: 26rpx;
  background: #ffffff;
  border: 2rpx solid rgba(224, 229, 226, 0.9);
  border-radius: 24rpx;
}

.field-textarea {
  min-height: 140rpx;
}

.detail-action-head {
  align-items: flex-start;
}

.upload-btn {
  flex-shrink: 0;
}

.photo-note {
  margin-top: 22rpx;
}

.photo-note-title {
  color: #2e2823;
  font-size: 24rpx;
  font-weight: 700;
}

.photo-note-text {
  margin-top: 10rpx;
  color: #65716d;
  font-size: 24rpx;
  line-height: 1.68;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.photo-cell {
  position: relative;
  overflow: hidden;
  border-radius: 26rpx;
}

.photo-thumb {
  width: 100%;
  height: 220rpx;
  border-radius: 26rpx;
}

.photo-index {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 8rpx 14rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(46, 40, 35, 0.56);
  border-radius: 999rpx;
}

.photo-remove {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  min-width: 92rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  color: #b45849;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
}

.upload-empty {
  margin-top: 20rpx;
  padding: 44rpx 28rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx dashed rgba(77, 192, 133, 0.28);
  border-radius: 32rpx;
}

.upload-plus {
  color: #31a381;
  font-size: 48rpx;
  font-weight: 700;
}

.detail-sub-title {
  margin-top: 24rpx;
}

.preview-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.preview-image {
  display: inline-block;
  width: 260rpx;
  height: 182rpx;
  margin-right: 14rpx;
  overflow: hidden;
  vertical-align: top;
  border-radius: 24rpx;
}

.retry-btn,
.select-btn {
  margin-top: 24rpx;
}
