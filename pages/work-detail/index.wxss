.work-detail-page {
  padding-bottom: 72rpx;
}

.detail-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-card {
  overflow: hidden;
}

.detail-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-time {
  color: #7f8a86;
  font-size: 22rpx;
}

.detail-cover {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.detail-cover-image {
  width: 100%;
  height: 360rpx;
  border: 12rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  box-sizing: border-box;
}

.detail-title {
  margin-top: 18rpx;
  color: #2e2823;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.22;
}

.detail-subtitle {
  margin-top: 10rpx;
  color: #65716d;
  font-size: 24rpx;
}

.detail-copy {
  margin-top: 18rpx;
  color: #65716d;
  font-size: 26rpx;
  line-height: 1.76;
}

.info-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  color: #7f8a86;
  font-size: 22rpx;
}

.info-value {
  color: #2e2823;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.58;
}

.detail-meta-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.detail-meta-card {
  flex: 1;
}

.detail-meta-label {
  color: #7f8a86;
  font-size: 22rpx;
}

.detail-meta-value {
  margin-top: 10rpx;
  color: #2e2823;
  font-size: 28rpx;
  font-weight: 800;
}

.rule-note {
  margin-top: 20rpx;
}

.rule-text {
  color: #65716d;
  font-size: 24rpx;
  line-height: 1.7;
}

.rule-text + .rule-text {
  margin-top: 10rpx;
}

.detail-btn + .detail-btn {
  margin-top: 16rpx;
}
