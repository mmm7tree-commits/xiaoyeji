.preview-page {
  padding-bottom: 156rpx;
}

.preview-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.preview-copy {
  flex: 1;
  min-width: 0;
}

.preview-title {
  margin-top: 18rpx;
  color: #2e2823;
  font-size: 42rpx;
  font-weight: 800;
  word-break: break-word;
}

.preview-meta {
  margin-top: 10rpx;
  color: #7f8a86;
  font-size: 24rpx;
}

.preview-layout {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  color: #2f7a61;
  font-size: 22rpx;
  font-weight: 700;
  background: #e8f7f0;
  border-radius: 999rpx;
}

.preview-price {
  color: #31a381;
  font-size: 36rpx;
  font-weight: 800;
}

.preview-note {
  margin-top: 24rpx;
  color: #65716d;
  font-size: 24rpx;
  line-height: 1.74;
}

.mobile-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 12rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 0%, rgba(77, 192, 133, 0.08), transparent 220rpx),
    linear-gradient(180deg, #f7f3ea 0%, #fbfaf6 100%);
}

.page-flip-swiper {
  width: 100%;
}

.page-shell-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.page-stage {
  position: relative;
  margin: 0 auto;
}

.page-shadow,
.paper-sheet {
  position: absolute;
  top: 0;
  left: 0;
}

.page-shadow {
  border-radius: 36rpx;
}

.page-shadow.back {
  background: rgba(102, 92, 72, 0.12);
  transform: translateY(24rpx) scale(0.94);
}

.page-shadow.middle {
  background: rgba(102, 92, 72, 0.18);
  transform: translateY(12rpx) scale(0.97);
}

.paper-sheet {
  overflow: hidden;
  padding: 28rpx 24rpx 24rpx;
  background: #ffffff;
  border: 10rpx solid rgba(255, 255, 255, 0.94);
  border-radius: 36rpx;
  box-shadow: 0 22rpx 42rpx rgba(46, 40, 35, 0.14);
}

.paper-sheet.format-square {
  border-radius: 34rpx;
}

.paper-sheet.format-portrait {
  padding: 34rpx 24rpx 28rpx;
  border-radius: 42rpx;
}

.paper-sheet.format-landscape {
  padding: 22rpx 24rpx 20rpx;
  border-radius: 28rpx;
}

.paper-sheet.theme-summer {
  background:
    radial-gradient(circle at 88% 12%, rgba(243, 183, 79, 0.16), transparent 120rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 250, 248, 0.96) 100%);
}

.paper-sheet.theme-ceremony {
  background:
    linear-gradient(180deg, rgba(170, 214, 237, 0.2) 0, rgba(170, 214, 237, 0.2) 20rpx, transparent 20rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 248, 251, 0.96) 100%);
}

.paper-sheet.theme-growth {
  background:
    radial-gradient(circle at 12% 14%, rgba(184, 221, 164, 0.16), transparent 118rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 250, 245, 0.96) 100%);
}

.paper-sheet.theme-classroom {
  background:
    repeating-linear-gradient(0deg, rgba(232, 239, 234, 0.72) 0, rgba(232, 239, 234, 0.72) 2rpx, transparent 2rpx, transparent 46rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 249, 246, 0.96) 100%);
}

.paper-sheet.theme-illustration {
  background:
    radial-gradient(circle at 14% 16%, rgba(249, 198, 162, 0.18), transparent 110rpx),
    radial-gradient(circle at 86% 82%, rgba(140, 203, 155, 0.16), transparent 128rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 248, 245, 0.96) 100%);
}

.paper-sheet.theme-portrait {
  background:
    linear-gradient(90deg, rgba(246, 221, 168, 0.18) 0, rgba(246, 221, 168, 0.18) 26rpx, transparent 26rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 249, 252, 0.96) 100%);
}

.paper-sheet.theme-storybook {
  background:
    linear-gradient(180deg, rgba(167, 217, 246, 0.2) 0, rgba(167, 217, 246, 0.2) 28rpx, transparent 28rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 246, 239, 0.96) 100%);
}

.paper-sheet.theme-clean {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 248, 245, 0.96) 100%);
}

.sheet-top,
.sheet-title,
.sheet-subtitle,
.page-layout {
  position: relative;
  z-index: 1;
}

.sheet-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.sheet-page-no {
  color: rgba(49, 163, 129, 0.72);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.sheet-type {
  padding: 8rpx 14rpx;
  color: #557480;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(229, 244, 246, 0.94);
  border-radius: 999rpx;
}

.sheet-title {
  margin-top: 20rpx;
  color: #2e2823;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.28;
}

.paper-sheet.format-landscape .sheet-title {
  margin-top: 16rpx;
  font-size: 30rpx;
}

.sheet-subtitle {
  min-height: 72rpx;
  margin-top: 10rpx;
  color: #65716d;
  font-size: 22rpx;
  line-height: 1.64;
}

.paper-sheet.format-landscape .sheet-subtitle {
  min-height: 60rpx;
}

.page-layout {
  display: flex;
  flex-direction: column;
  min-height: 0;
  margin-top: 22rpx;
}

.sheet-caption {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 10rpx 16rpx;
  color: #2f7a61;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
}

.cover-layout {
  position: relative;
}

.cover-photo {
  width: 100%;
  height: 100%;
  min-height: 420rpx;
  border-radius: 28rpx;
}

.paper-sheet.format-portrait .cover-photo {
  min-height: 580rpx;
}

.paper-sheet.format-landscape .cover-photo {
  min-height: 250rpx;
}

.cover-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 16rpx 22rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  background: rgba(49, 163, 129, 0.9);
  border-radius: 999rpx;
}

.hero-layout,
.single-layout {
  height: 100%;
}

.hero-photo,
.single-photo {
  width: 100%;
  border-radius: 28rpx;
}

.hero-photo {
  height: 430rpx;
}

.single-photo {
  height: 392rpx;
}

.paper-sheet.format-portrait .hero-photo {
  height: 560rpx;
}

.paper-sheet.format-portrait .single-photo {
  height: 620rpx;
}

.paper-sheet.format-landscape .hero-photo {
  height: 228rpx;
}

.paper-sheet.format-landscape .single-photo {
  height: 240rpx;
}

.duo-layout {
  gap: 14rpx;
  height: 100%;
}

.duo-cell {
  flex: 1;
  min-height: 0;
}

.duo-photo {
  width: 100%;
  height: 100%;
  border-radius: 26rpx;
}

.paper-sheet.format-landscape .duo-layout {
  flex-direction: row;
  flex-wrap: wrap;
}

.paper-sheet.format-landscape .duo-cell {
  width: calc((100% - 14rpx) / 2);
  flex: none;
}

.paper-sheet.format-landscape .duo-layout .sheet-caption {
  width: 100%;
}

.mosaic-layout,
.grid-layout {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mosaic-cell,
.grid-cell {
  min-height: 0;
}

.mosaic-cell {
  width: calc((100% - 12rpx) / 2);
  height: 178rpx;
}

.paper-sheet.format-portrait .mosaic-cell {
  height: 290rpx;
}

.paper-sheet.format-landscape .mosaic-cell {
  width: calc((100% - 24rpx) / 3);
  height: 138rpx;
}

.mosaic-photo,
.grid-photo,
.timeline-photo,
.quote-photo,
.letter-photo {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.grid-cell {
  width: calc((100% - 12rpx) / 2);
  height: 178rpx;
}

.paper-sheet.format-portrait .grid-cell {
  height: 276rpx;
}

.paper-sheet.format-landscape .grid-cell {
  height: 136rpx;
}

.timeline-layout {
  gap: 14rpx;
}

.timeline-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 108rpx;
}

.timeline-dot {
  flex: 0 0 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: #4dc085;
  border-radius: 50%;
  box-shadow: 0 0 0 8rpx rgba(77, 192, 133, 0.12);
}

.timeline-photo-shell {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 98rpx;
}

.paper-sheet.format-portrait .timeline-photo-shell {
  flex-basis: 160rpx;
  width: 160rpx;
  height: 120rpx;
}

.paper-sheet.format-landscape .timeline-photo-shell {
  flex-basis: 148rpx;
  width: 148rpx;
  height: 104rpx;
}

.timeline-copy {
  flex: 1;
  color: #2f7a61;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
}

.quote-layout,
.letter-layout {
  gap: 18rpx;
  height: 100%;
}

.quote-card {
  padding: 24rpx 22rpx;
  color: #2e2823;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.72;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 26rpx;
}

.paper-sheet.format-landscape .quote-card {
  font-size: 24rpx;
}

.quote-photo {
  flex: 1;
  min-height: 0;
}

.letter-copy {
  color: #2e2823;
  font-size: 26rpx;
  line-height: 1.82;
}

.paper-sheet.format-landscape .letter-copy {
  font-size: 22rpx;
  line-height: 1.72;
}

.letter-photo {
  height: 246rpx;
}

.paper-sheet.format-portrait .letter-photo {
  height: 340rpx;
}

.paper-sheet.format-landscape .letter-photo {
  height: 150rpx;
}

.photo-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  color: #9aa7a2;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx dashed rgba(77, 192, 133, 0.28);
  border-radius: 24rpx;
}

.cover-placeholder {
  min-height: 420rpx;
}

.hero-placeholder,
.single-placeholder {
  height: 100%;
  min-height: 360rpx;
}

.duo-placeholder,
.quote-placeholder,
.letter-placeholder {
  height: 100%;
  min-height: 180rpx;
}

.small-placeholder {
  height: 100%;
  min-height: 132rpx;
}

.timeline-placeholder {
  height: 100%;
}

.flip-toolbar {
  margin-top: 22rpx;
}

.flip-status {
  min-width: 0;
}

.flip-index {
  color: #2e2823;
  font-size: 30rpx;
  font-weight: 800;
}

.flip-label {
  margin-top: 8rpx;
  color: #7f8a86;
  font-size: 22rpx;
}

.flip-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.flip-btn {
  flex: 1;
}

.reference-scroll {
  width: 100%;
  white-space: nowrap;
}

.reference-card {
  position: relative;
  display: inline-block;
  width: 320rpx;
  height: 220rpx;
  margin-right: 18rpx;
  overflow: hidden;
  vertical-align: top;
  background: #ffffff;
  border: 8rpx solid rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 26rpx rgba(46, 40, 35, 0.08);
}

.reference-image {
  width: 100%;
  height: 100%;
}

.reference-label {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 14rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(46, 40, 35, 0.62);
  border-radius: 999rpx;
}

.bottom-actions {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(229, 235, 231, 0.94);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 40rpx rgba(46, 40, 35, 0.12);
}

.bottom-actions button {
  flex: 1;
}
