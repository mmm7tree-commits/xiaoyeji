.works-page {
  padding-bottom: 72rpx;
}

.section-head .ghost-btn {
  width: 156rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 148rpx;
  min-height: 68rpx;
  padding: 0 26rpx;
  color: #6e7875;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(220, 228, 224, 0.96);
  border-radius: 999rpx;
  box-sizing: border-box;
}

.filter-pill.active {
  color: #2f7a61;
  background: #e9f7f0;
  border-color: rgba(49, 163, 129, 0.28);
}

.work-list {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.work-card {
  padding: 20rpx;
}

.work-cover {
  position: relative;
  overflow: hidden;
  height: 360rpx;
  border-radius: 28rpx;
}

.work-cover::after {
  position: absolute;
  right: -40rpx;
  bottom: -60rpx;
  width: 220rpx;
  height: 220rpx;
  content: "";
  background: rgba(255, 255, 255, 0.34);
  border-radius: 45% 55% 52% 48%;
}

.work-cover-img {
  position: absolute;
  left: 40rpx;
  top: 42rpx;
  width: 390rpx;
  height: 260rpx;
  border: 14rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  transform: rotate(-3deg);
}

.work-cover-placeholder {
  position: absolute;
  left: 40rpx;
  top: 56rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
}

.work-status {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 2;
  padding: 10rpx 18rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(46, 40, 35, 0.62);
  border-radius: 999rpx;
}

.work-body {
  padding: 24rpx 6rpx 4rpx;
}

.work-title {
  color: #2e2823;
  font-size: 34rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-meta {
  margin-top: 8rpx;
  color: #7f8a86;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-page-count {
  color: #31a381;
  font-size: 28rpx;
  font-weight: 800;
}

.work-info {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.work-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 120rpx;
  gap: 14rpx;
  margin-top: 26rpx;
}

.work-actions button {
  min-height: 78rpx;
  font-size: 24rpx;
}

.empty-btn {
  margin-top: 28rpx;
}
