<view class="page-shell profile-page">
  <view class="profile-card card">
    <image wx:if="{{hasAvatar}}" class="avatar" src="{{profile.avatarUrl}}" mode="aspectFill" lazy-load="true"></image>
    <view wx:else class="avatar placeholder">小</view>
    <view class="profile-info">
      <view class="profile-name">{{profileName}}</view>
      <view class="profile-text">{{profileText}}</view>
    </view>
    <button wx:if="{{showLoginButton}}" class="secondary-btn login-btn" bindtap="authorizeProfile">微信授权</button>
  </view>

  <view wx:if="{{loggedIn}}" class="section">
    <view class="section-title">订单状态</view>
    <view class="status-grid">
      <view wx:for="{{statusCards}}" wx:key="code" class="status-card soft-card" data-status="{{item.code}}" bindtap="openOrderList">
        <text class="status-count">{{item.countText}}</text>
        <text class="status-label">{{item.label}}</text>
        <text class="status-hint">{{item.hint}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="section card">
    <view class="section-title">我的内容</view>
    <view class="between menu-item" bindtap="goWorks">
      <view>
        <view class="menu-title">我的作品</view>
        <view class="menu-text">{{worksCountText}}</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="between menu-item" data-status="all" bindtap="openOrderList">
      <view>
        <view class="menu-title">我的订单</view>
        <view class="menu-text">{{ordersCountText}}</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="between menu-item" bindtap="goAddress">
      <view>
        <view class="menu-title">我的地址</view>
        <view class="menu-text">{{addressStatusText}}</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view wx:else class="section card login-state-card">
    <view class="section-title">登录后可以做什么</view>
    <view class="section-subtitle">先授权登录，再统一查看自己的作品、订单和地址。</view>
    <view class="login-state-list">
      <view class="soft-card login-state-item">
        <view class="menu-title">我的作品</view>
        <view class="menu-text">继续补图、回看预览、整理成册内容</view>
      </view>
      <view class="soft-card login-state-item">
        <view class="menu-title">我的订单</view>
        <view class="menu-text">查看待支付、待发货和已关闭订单</view>
      </view>
      <view class="soft-card login-state-item">
        <view class="menu-title">我的地址</view>
        <view class="menu-text">统一管理默认地址，确认订单时自动带出</view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="between menu-item" bindtap="callService">
      <view>
        <view class="menu-title">联系客服</view>
        <view class="menu-text">{{servicePhone}}</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="between menu-item" bindtap="goAdmin">
      <view>
        <view class="menu-title">运营后台</view>
        <view class="menu-text">查看数据、模板、作品与订单</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="between menu-item" bindtap="goWorks">
      <view>
        <view class="menu-title">返回作品集</view>
        <view class="menu-text">继续整理已经保存下来的纪念册内容</view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
