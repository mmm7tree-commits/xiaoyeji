page {
  min-height: 100%;
  color: #2e2823;
  background: #f5f6f5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  font: inherit;
  line-height: inherit;
  background: transparent;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

button[disabled] {
  opacity: 0.72;
}

image {
  display: block;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(77, 192, 133, 0.18), transparent 340rpx),
    radial-gradient(circle at 8% 12%, rgba(242, 167, 81, 0.12), transparent 300rpx),
    linear-gradient(180deg, #f5f6f5 0%, #f8fbf8 46%, #ffffff 100%);
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #2e2823;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #7f8a86;
  font-size: 24rpx;
}

.card {
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(230, 236, 232, 0.95);
  border-radius: 34rpx;
  box-shadow: 0 18rpx 46rpx rgba(46, 40, 35, 0.08);
}

.soft-card {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(229, 235, 231, 0.9);
  border-radius: 30rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  color: #2f7a61;
  font-size: 22rpx;
  font-weight: 600;
  background: #e8f7f0;
  border-radius: 999rpx;
}

.pill.green {
  color: #2f7a61;
  background: #dff8ec;
}

.pill.blue {
  color: #527483;
  background: #e5f4f6;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #4dc085 0%, #31a381 100%);
  box-shadow: 0 16rpx 34rpx rgba(49, 163, 129, 0.28);
}

.primary-btn:active,
.secondary-btn:active,
.ghost-btn:active {
  transform: scale(0.98);
}

.secondary-btn {
  color: #2f7a61;
  background: #e9f8f1;
  border: 2rpx solid rgba(77, 192, 133, 0.22);
}

.ghost-btn {
  min-height: 72rpx;
  color: #65716d;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(224, 229, 226, 0.9);
  font-size: 24rpx;
}

.danger-btn {
  color: #b45849;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.muted {
  color: #7f8a86;
}

.empty-state {
  padding: 56rpx 34rpx;
  color: #7f8a86;
  text-align: center;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx dashed rgba(77, 192, 133, 0.28);
  border-radius: 34rpx;
}

.empty-title {
  color: #2e2823;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #7f8a86;
  font-size: 24rpx;
  line-height: 1.7;
}

.text-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
